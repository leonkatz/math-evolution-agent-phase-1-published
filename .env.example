# ── Required ──────────────────────────────────────────────────────────────────
# Database password — any string works, just needs to be consistent.
POSTGRES_PASSWORD=changeme

# ── Training configuration (optional — these are the paper's defaults) ────────
# Random seed (controls weight initialisation and environment sampling).
# The 20-seed sweep in the paper used seeds 1–20. Try 42, 7, or 123 to match
# the controlled ablation experiments.
SEED=42

# Total environment steps. 15M matches the primary sweep; 30M matches the
# extended runs that reach Energy (L12). More steps = higher final level.
STEPS=15000000

# Parallel environments. 1 = single env (n_envs=1 sweep in paper, cleaner data).
# 4 = 4× throughput but step counts are multiplied by n_envs internally.
N_ENVS=1

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Port the training monitor is served on. Open http://localhost:8081 after
# docker compose up.
DASHBOARD_PORT=8081
